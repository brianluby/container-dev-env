{
    "name": "Dev Container with Secret Injection",
    "dockerComposeFile": ["../../docker-compose.yml"],
    "service": "dev",
    "workspaceFolder": "/workspace",

    // Mount chezmoi source and config for secret decryption
    "mounts": [
        "source=${localEnv:HOME}/.local/share/chezmoi,target=/home/dev/.local/share/chezmoi,type=bind,readonly",
        "source=${localEnv:HOME}/.config/chezmoi,target=/home/dev/.config/chezmoi,type=bind,readonly"
    ],

    // Post-create command to apply chezmoi (decrypt secrets)
    "postCreateCommand": "chezmoi apply --force",

    // NOTE: Do NOT use postAttachCommand to load secrets - it runs in a separate
    // shell that exits after completion, so environment variables won't persist.
    // Instead, source secrets-load.sh in your shell rc file (e.g., ~/.bashrc)
    // See docs/secrets-guide.md for integration instructions.

    // VS Code settings
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                // Add your preferred extensions here
            ]
        }
    },

    // Features (optional)
    "features": {
        // Chezmoi and age should be in the base image
        // Add other features as needed
    },

    // Environment variables (non-secret only!)
    // Secrets are loaded via secrets-load.sh
    "containerEnv": {
        "EDITOR": "code --wait"
    },

    // User
    "remoteUser": "dev"
}
