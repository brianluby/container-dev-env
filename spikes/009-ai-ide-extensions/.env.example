# Spike 009: AI IDE Extensions Environment Variables
# Copy to .env and fill in your API keys

# code-server authentication
CODE_SERVER_PASSWORD=password
SUDO_PASSWORD=password

# AI Provider API Keys
# At least one is required for AI features

# OpenAI (GPT-4, GPT-4o, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenRouter (aggregates multiple providers)
OPENROUTER_API_KEY=

# Google (Gemini) - used by some extensions
GOOGLE_AI_API_KEY=

# Azure OpenAI (if using Azure-hosted models)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
