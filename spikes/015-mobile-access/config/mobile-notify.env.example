# Mobile Notification Configuration
# Copy this file to mobile-notify.env and fill in your values

# Enable mobile notifications
MOBILE_NOTIFY_ENABLED=true

# Platform to use: ntfy, discord, slack, pushover, all
MOBILE_NOTIFY_PLATFORM=ntfy

# =============================================================================
# ntfy.sh Configuration (Recommended - Simple, Self-hostable)
# =============================================================================
# Topic name for your notifications (choose something unique/obscure)
NTFY_TOPIC=my-dev-alerts-abc123

# Server URL (default: https://ntfy.sh, or your self-hosted instance)
NTFY_SERVER=https://ntfy.sh

# =============================================================================
# Discord Webhook Configuration
# =============================================================================
# Create a webhook: Server Settings > Integrations > Webhooks > New Webhook
# Copy the webhook URL
DISCORD_WEBHOOK=

# =============================================================================
# Slack Webhook Configuration
# =============================================================================
# Create an app at https://api.slack.com/apps
# Enable Incoming Webhooks and create a webhook for your channel
SLACK_WEBHOOK=

# =============================================================================
# Pushover Configuration ($5 one-time purchase per platform)
# =============================================================================
# Create an application at https://pushover.net/apps/build
PUSHOVER_TOKEN=

# Your user key from https://pushover.net/
PUSHOVER_USER=
