# Voice Input Environment Variables
# Copy to ~/.config/voice-input/.env and fill in values as needed.
# These are only required for specific cleanup tiers.

# Required if cleanup_tier=cloud and cleanup_cloud_provider=claude
# ANTHROPIC_API_KEY=sk-ant-...

# Required if cleanup_tier=cloud and cleanup_cloud_provider=openai
# OPENAI_API_KEY=sk-...
