# AI IDE Extensions Layer
#
# Installs Continue and Cline extensions with MCP servers into OpenVSCode-Server.
# This stage is intended to be included in the main container image build.
#
# Prerequisites:
#   - OpenVSCode-Server installed and on PATH
#   - Node.js 22.x available (for npm)
#   - Python 3.11+ available (for pip)
#   - curl available for VSIX downloads
#
# Provides:
#   - Continue v1.2.14 extension (installed)
#   - Cline v3.51.0 extension (installed)
#   - @modelcontextprotocol/server-filesystem@2026.1.14 (global npm)
#   - mcp-server-git==2026.1.14 (pip)
#   - Telemetry domains blocked in /etc/hosts
#   - VS Code user settings (telemetry disabled)
#   - Cline MCP settings (globalStorage)

# --- Extension Installation ---

# Copy install script and run it to download + install pinned VSIX files
COPY src/scripts/install-extensions.sh /tmp/install-extensions.sh
RUN chmod +x /tmp/install-extensions.sh && \
    /tmp/install-extensions.sh && \
    rm -f /tmp/install-extensions.sh

# --- MCP Server Installation ---

# Install filesystem MCP server (npm, pinned version >= 0.6.4 for CVE patches)
RUN npm install -g @modelcontextprotocol/server-filesystem@2026.1.14

# Install git MCP server (Python package, official implementation)
RUN pip install --no-cache-dir mcp-server-git==2026.1.14

# --- Telemetry Blocking (Network Level) ---

# Append telemetry blocklist to /etc/hosts (defense-in-depth for Cline bugs)
COPY src/hosts.d/telemetry-block.conf /etc/hosts.d/telemetry-block.conf
RUN cat /etc/hosts.d/telemetry-block.conf >> /etc/hosts

# --- VS Code User Settings ---

# Create user settings directory and copy telemetry-disabled settings
RUN mkdir -p /root/.config/Code/User
COPY src/config/vscode/settings.json /root/.config/Code/User/settings.json

# --- Cline MCP Settings ---

# Create Cline globalStorage directory and copy MCP settings
RUN mkdir -p /root/.config/Code/User/globalStorage/saoudrizwan.claude-dev/settings
COPY src/config/cline/cline_mcp_settings.json \
     /root/.config/Code/User/globalStorage/saoudrizwan.claude-dev/settings/cline_mcp_settings.json

# --- Continue Configuration ---

# Create Continue config directory and install rendered config
RUN mkdir -p /root/.continue
COPY src/config/continue/config.yaml.tmpl /root/.continue/config.yaml

# --- Bridge Script ---

# Copy bridge-secrets script for entrypoint integration
COPY src/scripts/bridge-secrets.sh /usr/local/bin/bridge-secrets.sh
RUN chmod +x /usr/local/bin/bridge-secrets.sh

# --- Volume Mount Points ---
# The following paths should be mounted as Docker volumes for persistence:
#   /root/.continue/           - Continue config + secrets (config volume)
#   /root/.config/Code/User/   - VS Code settings, Cline globalStorage (vscode-user volume)
#   Extension install directory - Installed VSIX binaries (extensions volume)
