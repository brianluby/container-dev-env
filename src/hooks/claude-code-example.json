{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify.sh \"Agent task completed\" completed \"Task Done\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify.sh \"Agent needs attention\" approval_needed \"Approval Needed\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
