# EditorConfig for voice-input scripts
# Enforces shfmt-compatible formatting: 2-space indent, case indent
root = true

[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.yaml]
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.txt]
end_of_line = lf
insert_final_newline = true
