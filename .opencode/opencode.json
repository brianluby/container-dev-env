{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ag *": "allow",
      "fd *": "allow",
      "git *": "allow",
      "npm run *": "allow",
      "npm test *": "allow",
      "npm install": "allow",
      "npm ci": "allow",
      "yarn *": "allow",
      "pnpm *": "allow",
      "cargo *": "allow",
      "make *": "allow",
      "pytest *": "allow",
      "go test *": "allow",
      "go build *": "allow",
      "which *": "allow",
      "whereis *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "pwd": "allow",
      "git push --force *": "deny",
      "git push -f *": "deny",
      "git reset --hard *": "deny",
      "git clean -f *": "deny",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "sudo *": "deny",
      "chmod 777 *": "deny",
      "systemctl *": "deny",
      "service *": "deny",
      "kill -9 *": "deny",
      "mkfs *": "deny",
      "dd *": "deny",
      "git push *": "ask",
      "npm publish *": "ask",
      "cargo publish *": "ask",
      "cp *": "ask",
      "mv *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets/**": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny"
    },
    "edit": {
      "*": "ask",
      "src/**": "allow",
      "tests/**": "allow",
      "test/**": "allow",
      "lib/**": "allow"
    }
  }
}