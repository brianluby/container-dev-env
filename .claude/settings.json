      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(kill -9:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Write(*.config.*)",
